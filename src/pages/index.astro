---
import fs from 'node:fs';

const prompts = JSON.parse(fs.readFileSync('./data/prompts.json', 'utf-8'));

// 按分类组织数据
const categories = [...new Set(prompts.map((p: any) => p.category))];
const categoryData: Record<string, any> = {};

categories.forEach((cat: string) => {
  categoryData[cat] = [...new Set(prompts.filter((p: any) => p.category === cat).map((p: any) => p.tags?.[0]).filter(Boolean))];
});
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>提示词模板库</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    h1 {
      text-align: center;
      color: #fff;
      font-size: 2.5rem;
      margin-bottom: 40px;
      text-shadow: 0 0 20px rgba(100, 200, 255, 0.5);
    }
    
    /* 返回按钮 */
    .back-btn {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 10px 20px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.9rem;
      margin-bottom: 20px;
      transition: all 0.3s;
      display: none;
    }
    .back-btn:hover {
      background: rgba(255, 255, 255, 0.2);
    }
    .back-btn.visible {
      display: inline-block;
    }
    
    /* 大分类按钮 */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }
    .category-btn {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: #fff;
      border: none;
      padding: 30px 24px;
      border-radius: 16px;
      cursor: pointer;
      font-size: 1.4rem;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }
    .category-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
    }
    
    /* 子分类按钮 */
    .sub-category-grid {
      display: none;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 30px;
    }
    .sub-category-grid.visible {
      display: grid;
    }
    .sub-category-btn {
      background: rgba(255, 255, 255, 0.15);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 16px 24px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.3s;
    }
    .sub-category-btn:hover {
      background: rgba(255, 255, 255, 0.25);
      transform: translateY(-3px);
    }
    .sub-category-btn.active {
      background: linear-gradient(135deg, #00c6ff, #0072ff);
      border-color: transparent;
    }
    
    /* 提示词卡片 */
    .prompts-grid {
      display: none;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 24px;
    }
    .prompts-grid.visible {
      display: grid;
    }
    .card {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      padding: 24px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }
    .card h2 {
      color: #fff;
      font-size: 1.3rem;
      margin-bottom: 12px;
      padding-right: 80px;
    }
    .card .content {
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 16px;
      padding: 12px;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 8px;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .card .meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }
    .category-tag {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: #fff;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
    }
    .tag {
      background: rgba(255, 255, 255, 0.2);
      color: #fff;
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 0.75rem;
    }
    .date {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.8rem;
      margin-left: auto;
    }
    
    /* 复制按钮 */
    .copy-btn {
      position: absolute;
      top: 16px;
      right: 16px;
      background: linear-gradient(135deg, #00c6ff, #0072ff);
      color: #fff;
      border: none;
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.8rem;
      transition: all 0.3s;
      z-index: 10;
    }
    .copy-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 4px 15px rgba(0, 198, 255, 0.4);
    }
    .copy-btn.copied {
      background: linear-gradient(135deg, #11998e, #38ef7d);
    }
    
    .empty {
      text-align: center;
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.2rem;
      padding: 60px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🎨 提示词模板库</h1>
    
    <!-- 返回按钮 -->
    <button class="back-btn" id="backBtn" onclick="goBack()">← 返回上一级</button>
    
    <!-- 第一层：大分类 -->
    <div class="category-grid" id="categoryGrid">
      {categories.map((category: string) => (
        <button class="category-btn" onclick={`showSubCategories('${category}')`}>
          {category}
        </button>
      ))}
    </div>
    
    <!-- 第二层：子分类 -->
    <div class="sub-category-grid" id="subCategoryGrid"></div>
    
    <!-- 第三层：提示词卡片 -->
    <div class="prompts-grid" id="promptsGrid"></div>
  </div>

  <script define:vars={{ prompts, categoryData }}>
    let currentLevel = 0;
    let currentCategory = '';
    let currentSubCategory = '';
    
    function showSubCategories(category) {
      currentLevel = 1;
      currentCategory = category;
      currentSubCategory = '';
      
      // 隐藏大分类，显示子分类
      document.getElementById('categoryGrid').style.display = 'none';
      document.getElementById('subCategoryGrid').classList.add('visible');
      document.getElementById('promptsGrid').classList.remove('visible');
      document.getElementById('backBtn').classList.add('visible');
      
      // 渲染子分类
      const subCategories = categoryData[category] || [];
      const subGrid = document.getElementById('subCategoryGrid');
      subGrid.innerHTML = subCategories.map(sub => 
        `<button class="sub-category-btn" onclick="showPrompts('${sub}')">${sub}</button>`
      ).join('');
      
      // 清除卡片
      document.getElementById('promptsGrid').innerHTML = '';
    }
    
    function showPrompts(subCategory) {
      currentLevel = 2;
      currentSubCategory = subCategory;
      
      // 显示卡片
      document.getElementById('subCategoryGrid').classList.remove('visible');
      document.getElementById('promptsGrid').classList.add('visible');
      
      // 高亮当前子分类
      document.querySelectorAll('.sub-category-btn').forEach(btn => {
        btn.classList.toggle('active', btn.textContent === subCategory);
      });
      
      // 渲染卡片
      const filtered = prompts.filter(p => p.category === currentCategory && p.tags?.[0] === subCategory);
      const grid = document.getElementById('promptsGrid');
      
      grid.innerHTML = filtered.map((prompt, index) => `
        <div class="card">
          <button class="copy-btn" onclick="copyContent(this, ${index})">📋 一键复制</button>
          <h2>${prompt.title}</h2>
          <div class="content">${prompt.content}</div>
          <div class="meta">
            <span class="category-tag">${prompt.category}</span>
            ${prompt.tags?.map(tag => `<span class="tag">${tag}</span>`).join('')}
            <span class="date">${prompt.date}</span>
          </div>
        </div>
      `).join('');
    }
    
    function goBack() {
      if (currentLevel === 2) {
        // 从卡片返回子分类
        currentLevel = 1;
        document.getElementById('promptsGrid').classList.remove('visible');
        document.getElementById('subCategoryGrid').classList.add('visible');
      } else if (currentLevel === 1) {
        // 从子分类返回大分类
        currentLevel = 0;
        document.getElementById('subCategoryGrid').classList.remove('visible');
        document.getElementById('categoryGrid').style.display = 'grid';
        document.getElementById('backBtn').classList.remove('visible');
      }
      currentCategory = '';
      currentSubCategory = '';
    }
    
    function copyContent(btn, index) {
      const card = btn.closest('.card');
      const content = card.querySelector('.content').textContent;
      
      navigator.clipboard.writeText(content).then(() => {
        const originalText = btn.textContent;
        btn.textContent = '✅ 已复制!';
        btn.classList.add('copied');
        
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('copied');
        }, 2000);
      }).catch(err => {
        console.error('复制失败:', err);
        btn.textContent = '❌ 复制失败';
        setTimeout(() => {
          btn.textContent = '📋 一键复制';
        }, 2000);
      });
    }
  </script>
</body>
</html>
