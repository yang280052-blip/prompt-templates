---
import fs from 'node:fs';

const prompts = JSON.parse(fs.readFileSync('./data/prompts.json', 'utf-8'));

// 构建分类数据结构
const categories = [...new Set(prompts.map((p: any) => p.category))];

const categorySubs: Record<string, string[]> = {};
categories.forEach((cat: string) => {
  const items = prompts.filter((p: any) => p.category === cat);
  const tags = new Set<string>();
  items.forEach((p: any) => {
    if (p.tags) p.tags.forEach((t: string) => tags.add(t));
  });
  categorySubs[cat] = Array.from(tags);
});
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>提示词模板库</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }
    .container { max-width: 1000px; margin: 0 auto; }
    h1 {
      text-align: center;
      color: #fff;
      font-size: 2.8rem;
      margin-bottom: 50px;
      text-shadow: 0 0 30px rgba(100, 200, 255, 0.5);
      letter-spacing: 4px;
    }
    .back-btn {
      background: rgba(255, 255, 255, 0.15);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 12px 24px;
      border-radius: 25px;
      cursor: pointer;
      font-size: 0.95rem;
      margin-bottom: 30px;
      display: none;
    }
    .back-btn.visible { display: inline-block; }
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }
    .category-btn {
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.9) 0%, rgba(118, 75, 162, 0.9) 100%);
      color: #fff;
      border: none;
      padding: 40px 30px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 1.3rem;
      font-weight: 600;
      transition: all 0.3s;
    }
    .category-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(102, 126, 234, 0.5);
    }
    .category-btn .icon { font-size: 2rem; display: block; margin-bottom: 12px; }
    
    .sub-category-grid {
      display: none;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 40px;
    }
    .sub-category-grid.visible { display: grid; }
    .sub-category-btn {
      background: rgba(255, 255, 255, 0.15);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 18px 24px;
      border-radius: 14px;
      cursor: pointer;
      font-size: 1rem;
    }
    .sub-category-btn:hover { background: rgba(255, 255, 255, 0.25); }
    .sub-category-btn.active { background: linear-gradient(135deg, #00c6ff, #0072ff); }
    
    .prompts-grid {
      display: none;
      grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
      gap: 24px;
    }
    .prompts-grid.visible { display: grid; }
    .card {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 28px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      position: relative;
    }
    .card h2 { color: #fff; font-size: 1.2rem; margin-bottom: 16px; padding-right: 90px; }
    .card .content {
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.9rem;
      line-height: 1.7;
      margin-bottom: 20px;
      padding: 16px;
      background: rgba(0, 0, 0, 0.25);
      border-radius: 12px;
      white-space: pre-wrap;
      max-height: 180px;
      overflow-y: auto;
    }
    .card .meta { display: flex; gap: 10px; flex-wrap: wrap; }
    .category-tag {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: #fff;
      padding: 5px 14px;
      border-radius: 20px;
      font-size: 0.75rem;
    }
    .tag {
      background: rgba(255, 255, 255, 0.15);
      color: rgba(255, 255, 255, 0.8);
      padding: 5px 12px;
      border-radius: 15px;
      font-size: 0.75rem;
    }
    .copy-btn {
      position: absolute;
      top: 20px;
      right: 20px;
      background: linear-gradient(135deg, #00c6ff, #0072ff);
      color: #fff;
      border: none;
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 0.8rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🎨 提示词模板库</h1>
    <button class="back-btn" id="backBtn">← 返回上一级</button>
    
    <!-- 大分类 -->
    <div class="category-grid" id="categoryGrid">
      {categories.map((cat: string) => (
        <button class="category-btn" data-cat={cat}>
          <span class="icon">
            {cat === '文生图提示词模版' ? '✏️' : cat === '图生视频提示词模版' ? '🎬' : '✨'}
          </span>
          {cat}
        </button>
      ))}
    </div>
    
    <!-- 子分类 -->
    <div class="sub-category-grid" id="subCategoryGrid"></div>
    
    <!-- 提示词卡片 -->
    <div class="prompts-grid" id="promptsGrid"></div>
  </div>

  <script define:vars={{ prompts, categorySubs }}>
    let currentLevel = 0;
    let currentCategory = '';
    let currentSubCategory = '';
    
    // 大分类按钮点击
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        showSub(this.dataset.cat);
      });
    });
    
    // 返回按钮
    document.getElementById('backBtn').addEventListener('click', goBack);
    
    function showSub(cat) {
      console.log('showSub:', cat);
      currentLevel = 1;
      currentCategory = cat;
      
      document.getElementById('categoryGrid').style.display = 'none';
      document.getElementById('subCategoryGrid').classList.add('visible');
      document.getElementById('promptsGrid').classList.remove('visible');
      document.getElementById('backBtn').classList.add('visible');
      
      const subs = categorySubs[cat] || [];
      const subGrid = document.getElementById('subCategoryGrid');
      
      console.log('subs:', subs);
      
      if (subs.length === 0) {
        showPrompts('');
      } else {
        subGrid.innerHTML = subs.map(sub => 
          `<button class="sub-category-btn" data-sub="${sub}">${sub}</button>`
        ).join('');
        
        document.querySelectorAll('.sub-category-btn').forEach(btn => {
          btn.addEventListener('click', function() {
            showPrompts(this.dataset.sub);
          });
        });
      }
    }
    
    function showPrompts(subCat) {
      console.log('showPrompts:', subCat);
      currentLevel = 2;
      currentSubCategory = subCat;
      
      document.getElementById('subCategoryGrid').classList.remove('visible');
      document.getElementById('promptsGrid').classList.add('visible');
      
      const filtered = subCat 
        ? prompts.filter(p => p.category === currentCategory && p.tags?.includes(subCat))
        : prompts.filter(p => p.category === currentCategory);
      
      const grid = document.getElementById('promptsGrid');
      grid.innerHTML = filtered.map(prompt => `
        <div class="card">
          <button class="copy-btn">📋 复制</button>
          <h2>${prompt.title}</h2>
          <div class="content">${prompt.content}</div>
          <div class="meta">
            <span class="category-tag">${prompt.category}</span>
            ${(prompt.tags || []).map(tag => `<span class="tag">${tag}</span>`).join('')}
            <span class="tag">${prompt.date}</span>
          </div>
        </div>
      `).join('');
      
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const content = this.closest('.card').querySelector('.content').textContent;
          navigator.clipboard.writeText(content).then(() => {
            this.textContent = '✓ 已复制';
            setTimeout(() => this.textContent = '📋 复制', 2000);
          });
        });
      });
    }
    
    function goBack() {
      if (currentLevel === 2) {
        currentLevel = 1;
        document.getElementById('promptsGrid').classList.remove('visible');
        const subs = categorySubs[currentCategory] || [];
        if (subs.length > 0) {
          document.getElementById('subCategoryGrid').classList.add('visible');
        } else {
          document.getElementById('categoryGrid').style.display = 'grid';
          document.getElementById('backBtn').classList.remove('visible');
        }
      } else if (currentLevel === 1) {
        currentLevel = 0;
        document.getElementById('subCategoryGrid').classList.remove('visible');
        document.getElementById('categoryGrid').style.display = 'grid';
        document.getElementById('backBtn').classList.remove('visible');
      }
    }
  </script>
</body>
</html>
