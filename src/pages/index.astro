---
import fs from 'node:fs';

const prompts = JSON.parse(fs.readFileSync('./data/prompts.json', 'utf-8'));
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>提示词模板库</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    h1 {
      text-align: center;
      color: #fff;
      font-size: 2.5rem;
      margin-bottom: 40px;
      text-shadow: 0 0 20px rgba(100, 200, 255, 0.5);
    }
    .section-title {
      color: #fff;
      font-size: 1.8rem;
      margin: 40px 0 24px 0;
      padding-bottom: 12px;
      border-bottom: 2px solid rgba(255, 255, 255, 0.2);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 24px;
    }
    .card {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      padding: 24px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: transform 0.3s, box-shadow 0.3s;
      position: relative;
    }
    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }
    .card h2 {
      color: #fff;
      font-size: 1.3rem;
      margin-bottom: 12px;
      padding-right: 60px;
    }
    .card .content {
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 16px;
      padding: 12px;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 8px;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .card .meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }
    .category {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: #fff;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
    }
    .tag {
      background: rgba(255, 255, 255, 0.2);
      color: #fff;
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 0.75rem;
    }
    .date {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.8rem;
      margin-left: auto;
    }
    .copy-btn {
      position: absolute;
      top: 16px;
      right: 16px;
      background: linear-gradient(135deg, #00c6ff, #0072ff);
      color: #fff;
      border: none;
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.85rem;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .copy-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 4px 15px rgba(0, 198, 255, 0.4);
    }
    .copy-btn.copied {
      background: linear-gradient(135deg, #00d2ff, #3a7bd5);
    }
    .empty {
      text-align: center;
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.2rem;
      padding: 60px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🎨 提示词模板库</h1>
    
    {prompts.length > 0 ? (
      <>
        {(() => {
          const categories = [...new Set(prompts.map((p: any) => p.category))];
          return categories.map((category: any) => (
            <>
              <h2 class="section-title">{category}</h2>
              <div class="grid">
                {prompts.filter((p: any) => p.category === category).map((prompt: any, index: number) => (
                  <div class="card">
                    <button class="copy-btn" onclick={`copyToClipboard(${index}, '${category.replace(/'/g, "\\'")}')`}>
                      📋 一键复制
                    </button>
                    <h2>{prompt.title}</h2>
                    <div class="content" id={`content-${category}-${index}`}>{prompt.content}</div>
                    <div class="meta">
                      <span class="category">{prompt.category}</span>
                      {prompt.tags?.map((tag: string) => (
                        <span class="tag">{tag}</span>
                      ))}
                      <span class="date">{prompt.date}</span>
                    </div>
                  </div>
                ))}
              </div>
            </>
          ));
        })()}
      </>
    ) : (
      <div class="empty">暂无提示词</div>
    )}
  </div>

  <script>
    function copyToClipboard(index, category) {
      const contentEl = document.querySelector(`[id^="content-"]`);
      const cards = document.querySelectorAll('.card');
      const cardArray = Array.from(cards);
      
      // Find the clicked card
      const clickedCard = cardArray[index];
      if (!clickedCard) return;
      
      const content = clickedCard.querySelector('.content').textContent;
      
      navigator.clipboard.writeText(content).then(() => {
        const btn = clickedCard.querySelector('.copy-btn');
        const originalText = btn.textContent;
        btn.textContent = '✅ 已复制!';
        btn.classList.add('copied');
        
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('copied');
        }, 2000);
      });
    }
  </script>
</body>
</html>
